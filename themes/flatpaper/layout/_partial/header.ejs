<header class="site-header">
  <%
  // Menu entry helpers shared with sidebar-right.ejs — see scripts/menu-helpers.js.
  var __menu = flatpaper_menu_helpers();
  var menuChildren = __menu.children, menuHref = __menu.href, menuIcon = __menu.icon, menuText = __menu.text, menuActive = __menu.active;
  %>
  <button class="icon-button js-sidebar-toggle sidebar-toggle" type="button" aria-label="<%= flatpaper_i18n('navigation.open_sidebar') %>" aria-controls="paper-sidebar-drawer" aria-expanded="false">
    <%- partial('_partial/icons', { icon: 'menu' }) %>
  </button>

  <div class="brand">
    <div class="brand-mark-wrapper">
      <% if (theme.nav && theme.nav.enable) { %>
        <button class="brand-mark" type="button" aria-label="<%= flatpaper_i18n('navigation.brand_menu') %>" aria-haspopup="true" aria-expanded="false" aria-controls="brand-nav-menu">
          <%- partial('_partial/icons', { icon: 'layout-grid' }) %>
        </button>
        <div class="brand-nav-menu" id="brand-nav-menu" role="menu">
          <% (theme.nav.menu || []).forEach(function(group) { %>
            <div class="brand-nav-group">
              <div class="brand-nav-title"><%= group.title %></div>
              <% (group.item || []).forEach(function(item) { %>
                <a role="menuitem" href="<%= flatpaper_safe_url(item.link, 'href') %>" target="_blank" rel="noopener noreferrer">
                  <% if (item.icon && item.icon.indexOf('http') === 0) { %>
                    <img src="<%= flatpaper_safe_url(item.icon, 'image') %>" alt="" class="nav-img-icon" aria-hidden="true" />
                  <% } else if (item.icon) { %>
                    <%- partial('_partial/icons', { icon: item.icon }) %>
                  <% } %>
                  <span><%= item.name %></span>
                </a>
              <% }) %>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <a class="brand-mark" href="<%- url_for('/') %>" aria-label="<%= flatpaper_i18n('navigation.brand_home') %>">
          <%- partial('_partial/icons', { icon: 'layout-grid' }) %>
        </a>
      <% } %>
    </div>
    <a class="brand-text" href="<%- url_for('/') %>"><%= config.title || 'FlatPaper' %></a>
  </div>

  <nav class="site-nav" aria-label="<%= flatpaper_i18n('navigation.primary') %>">
    <% Object.keys(theme.menu || {}).forEach(function(label) {
      var item = theme.menu[label];
      var href = menuHref(item);
      var icon = menuIcon(item);
      var text = menuText(label, item);
      var children = menuChildren(item);
      var active = href ? menuActive(href) : false;
      children.forEach(function (child) { if (menuActive(menuHref(child.item))) active = true; });
    %>
      <% if (children.length) { %>
        <div class="site-nav-item has-children<%= active ? ' active' : '' %>">
          <button class="site-nav-link site-nav-parent" type="button" aria-haspopup="true" aria-expanded="false">
            <% if (icon) { %><%- partial('_partial/icons', { icon: icon }) %><% } %>
            <span><%= text %></span>
          </button>
          <div class="site-nav-menu" role="menu">
            <% children.forEach(function (child) {
              var childItem = child.item;
              var childHref = menuHref(childItem) || '#';
              var childIcon = menuIcon(childItem);
              var childText = menuText(child.label, childItem);
              var childActive = menuActive(childHref);
            %>
              <a role="menuitem" class="<%= childActive ? 'active' : '' %>" href="<%= flatpaper_safe_url(url_for(String(childHref)), 'href') %>">
                <% if (childIcon) { %><%- partial('_partial/icons', { icon: childIcon }) %><% } %>
                <span><%= childText %></span>
              </a>
            <% }) %>
          </div>
        </div>
      <% } else { %>
        <a class="site-nav-link <%= active ? 'active' : '' %>" href="<%= flatpaper_safe_url(url_for(String(href || '/')), 'href') %>">
          <% if (icon) { %><%- partial('_partial/icons', { icon: icon }) %><% } %>
          <span><%= text %></span>
        </a>
      <% } %>
    <% }) %>
  </nav>

  <div class="header-tools">
    <button class="icon-button js-search-open" type="button" aria-label="<%= flatpaper_i18n('common.search_posts') %>">
      <%- partial('_partial/icons', { icon: 'search' }) %>
    </button>
    <div class="accent-picker">
      <button class="icon-button accent-toggle" type="button" aria-label="<%= flatpaper_i18n('colors.choose_theme_color') %>" title="<%= flatpaper_i18n('colors.choose_theme_color') %>" aria-haspopup="true" aria-expanded="false" aria-controls="accent-menu">
        <%- partial('_partial/icons', { icon: 'palette' }) %>
      </button>
      <div class="accent-menu" id="accent-menu" role="menu" aria-label="<%= flatpaper_i18n('colors.theme_color') %>">
        <button type="button" class="accent-option" role="menuitemradio" aria-label="<%= flatpaper_i18n('colors.orange') %>" aria-checked="false" data-accent-option="orange">
          <span class="accent-swatch accent-swatch--orange" aria-hidden="true"></span>
        </button>
        <button type="button" class="accent-option" role="menuitemradio" aria-label="<%= flatpaper_i18n('colors.purple') %>" aria-checked="false" data-accent-option="purple">
          <span class="accent-swatch accent-swatch--purple" aria-hidden="true"></span>
        </button>
        <button type="button" class="accent-option" role="menuitemradio" aria-label="<%= flatpaper_i18n('colors.sakura') %>" aria-checked="false" data-accent-option="sakura">
          <span class="accent-swatch accent-swatch--sakura" aria-hidden="true"></span>
        </button>
        <button type="button" class="accent-option" role="menuitemradio" aria-label="<%= flatpaper_i18n('colors.blue') %>" aria-checked="false" data-accent-option="blue">
          <span class="accent-swatch accent-swatch--blue" aria-hidden="true"></span>
        </button>
        <button type="button" class="accent-option" role="menuitemradio" aria-label="<%= flatpaper_i18n('colors.pink') %>" aria-checked="false" data-accent-option="pink">
          <span class="accent-swatch accent-swatch--pink" aria-hidden="true"></span>
        </button>
        <button type="button" class="accent-option" role="menuitemradio" aria-label="<%= flatpaper_i18n('colors.green') %>" aria-checked="false" data-accent-option="green">
          <span class="accent-swatch accent-swatch--green" aria-hidden="true"></span>
        </button>
        <button type="button" class="accent-option" role="menuitemradio" aria-label="<%= flatpaper_i18n('colors.black') %>" aria-checked="false" data-accent-option="black">
          <span class="accent-swatch accent-swatch--black" aria-hidden="true"></span>
        </button>
      </div>
    </div>
    <button class="theme-toggle" type="button" aria-label="<%= flatpaper_i18n('colors.toggle_color_mode') %>">
      <span class="theme-icon theme-icon--sun"><%- partial('_partial/icons', { icon: 'sun' }) %></span>
      <span class="theme-icon theme-icon--moon"><%- partial('_partial/icons', { icon: 'moon' }) %></span>
    </button>
  </div>
</header>
