<%
var allPosts = flatpaper_sorted_posts();
var categories = site.categories ? site.categories.toArray() : [];
var tags = site.tags ? site.tags.toArray() : [];
var profile = theme.profile || {};
var socials = profile.social || theme.social || {};
var rss = profile.rss || theme.rss || {};
function siteInfoEntry(value) {
  if (value === false || value == null) return false;
  if (value === true) return { href: '' };
  if (value && typeof value === 'object' && !Array.isArray(value)) {
    return siteInfoEntry(value.link);
  }
  var href = String(value || '').trim();
  return href ? { href: href } : false;
}
function siteInfoConfig(key) {
  var info = profile.site_info;
  if (info === true) return siteInfoEntry(true);
  if (info === false || !info) return false;
  if (typeof info === 'object' && Object.prototype.hasOwnProperty.call(info, key)) {
    return siteInfoEntry(info[key]);
  }
  return false;
}
function siteInfoUrl(href) {
  var value = String(href || '').trim();
  if (!value) return '';
  if (/^(?:[a-z][a-z0-9+.-]*:|\/\/)/i.test(value)) return flatpaper_safe_url(value, 'href');
  return flatpaper_safe_url(url_for(value), 'href');
}
var siteInfoItems = [
  { key: 'posts', value: allPosts.length, label: flatpaper_i18n('common.posts') },
  { key: 'categories', value: categories.length, label: flatpaper_i18n('common.categories') },
  { key: 'tags', value: tags.length, label: flatpaper_i18n('common.tags') }
].map(function (item) {
  var entry = siteInfoConfig(item.key);
  if (!entry) return null;
  item.href = siteInfoUrl(entry.href);
  return item;
}).filter(Boolean);
// Menu entry helpers shared with header.ejs — see scripts/menu-helpers.js.
var __menu = flatpaper_menu_helpers();
var menuChildren = __menu.children, menuHref = __menu.href, menuIcon = __menu.icon, menuText = __menu.text, menuActive = __menu.active;
%>

<aside id="paper-sidebar-drawer" class="paper-sidebar paper-sidebar--right" aria-label="<%= flatpaper_i18n('navigation.sidebar') %>">
  <div class="drawer-toolbar" aria-label="<%= flatpaper_i18n('navigation.sidebar_tools') %>">
    <div class="drawer-accent-options" role="group" aria-label="<%= flatpaper_i18n('colors.theme_color') %>">
      <button type="button" class="accent-option" aria-label="<%= flatpaper_i18n('colors.orange') %>" aria-pressed="false" data-accent-option="orange">
        <span class="accent-swatch accent-swatch--orange" aria-hidden="true"></span>
      </button>
      <button type="button" class="accent-option" aria-label="<%= flatpaper_i18n('colors.purple') %>" aria-pressed="false" data-accent-option="purple">
        <span class="accent-swatch accent-swatch--purple" aria-hidden="true"></span>
      </button>
      <button type="button" class="accent-option" aria-label="<%= flatpaper_i18n('colors.sakura') %>" aria-pressed="false" data-accent-option="sakura">
        <span class="accent-swatch accent-swatch--sakura" aria-hidden="true"></span>
      </button>
      <button type="button" class="accent-option" aria-label="<%= flatpaper_i18n('colors.blue') %>" aria-pressed="false" data-accent-option="blue">
        <span class="accent-swatch accent-swatch--blue" aria-hidden="true"></span>
      </button>
      <button type="button" class="accent-option" aria-label="<%= flatpaper_i18n('colors.pink') %>" aria-pressed="false" data-accent-option="pink">
        <span class="accent-swatch accent-swatch--pink" aria-hidden="true"></span>
      </button>
      <button type="button" class="accent-option" aria-label="<%= flatpaper_i18n('colors.green') %>" aria-pressed="false" data-accent-option="green">
        <span class="accent-swatch accent-swatch--green" aria-hidden="true"></span>
      </button>
      <button type="button" class="accent-option" aria-label="<%= flatpaper_i18n('colors.black') %>" aria-pressed="false" data-accent-option="black">
        <span class="accent-swatch accent-swatch--black" aria-hidden="true"></span>
      </button>
    </div>
    <button class="icon-button drawer-close js-sidebar-close" type="button" aria-label="<%= flatpaper_i18n('navigation.close_sidebar') %>">
      <%- partial('_partial/icons', { icon: 'x' }) %>
    </button>
  </div>

  <section class="side-card nav-card">
    <nav class="site-nav-drawer" aria-label="<%= flatpaper_i18n('navigation.mobile') %>">
      <% Object.keys(theme.menu || {}).forEach(function(label) {
        var item = theme.menu[label];
        var href = menuHref(item);
        var icon = menuIcon(item);
        var text = menuText(label, item);
        var children = menuChildren(item);
        var active = href ? menuActive(href) : false;
        children.forEach(function (child) { if (menuActive(menuHref(child.item))) active = true; });
      %>
        <% if (children.length) { %>
          <div class="drawer-nav-group<%= active ? ' is-open active' : '' %>">
            <button class="drawer-nav-parent" type="button" aria-expanded="<%= active ? 'true' : 'false' %>">
              <% if (icon) { %><%- partial('_partial/icons', { icon: icon }) %><% } %>
              <span><%= text %></span>
            </button>
            <div class="drawer-nav-children">
              <% children.forEach(function (child) {
                var childItem = child.item;
                var childHref = menuHref(childItem) || '#';
                var childIcon = menuIcon(childItem);
                var childText = menuText(child.label, childItem);
                var childActive = menuActive(childHref);
              %>
                <a class="<%= childActive ? 'active' : '' %>" href="<%= flatpaper_safe_url(url_for(String(childHref)), 'href') %>">
                  <% if (childIcon) { %><%- partial('_partial/icons', { icon: childIcon }) %><% } %>
                  <span><%= childText %></span>
                </a>
              <% }) %>
            </div>
          </div>
        <% } else { %>
          <a class="<%= active ? 'active' : '' %>" href="<%= flatpaper_safe_url(url_for(String(href || '/')), 'href') %>">
            <% if (icon) { %><%- partial('_partial/icons', { icon: icon }) %><% } %>
            <span><%= text %></span>
          </a>
        <% } %>
      <% }) %>
    </nav>
  </section>

  <section class="side-card profile-card">
    <% if (profile.avatar) { %>
      <div class="avatar avatar--image<%= profile.avatar_shape === 'circle' ? ' avatar--circle' : '' %>">
        <img src="<%= flatpaper_safe_url(url_for(profile.avatar), 'image') %>" alt="<%= config.author || '' %>" loading="lazy" referrerpolicy="no-referrer">
      </div>
    <% } else { %>
      <div class="avatar" aria-hidden="true">
        <span></span><i></i><em></em><b></b>
      </div>
    <% } %>
    <h3><%= config.title || config.author || 'FlatPaper' %></h3>
    <% if (profile.role) { %><p class="profile-role"><%= profile.role %></p><% } %>
    <p><%= profile.bio || flatpaper_i18n('profile.default_bio') %></p>
    <% if (siteInfoItems.length) { %>
      <div class="site-info" aria-label="<%= flatpaper_i18n('navigation.site_info') %>">
        <% siteInfoItems.forEach(function(item) { %>
          <% if (item.href) { %>
            <a class="site-info__item" href="<%= item.href %>">
              <strong><%= item.value %></strong>
              <span><%= item.label %></span>
            </a>
          <% } else { %>
            <div class="site-info__item">
              <strong><%= item.value %></strong>
              <span><%= item.label %></span>
            </div>
          <% } %>
        <% }) %>
      </div>
    <% } %>
    <div class="socials">
      <% Object.keys(socials).forEach(function(name) {
        var raw = socials[name];
        var entry = (raw && typeof raw === 'object') ? raw : { url: raw };
        var href = entry.url || entry.href || '';
        if (!href) { return; }
        var key = name.toLowerCase();
        var iconMap = {
          github: 'github', twitter: 'twitter', x: 'x-twitter',
          email: 'mail', mail: 'mail', rss: 'rss',
          steam: 'steam', bilibili: 'bilibili', youtube: 'youtube',
          facebook: 'facebook', instagram: 'instagram',
          telegram: 'telegram', weibo: 'weibo'
        };
        var iconName = entry.icon || iconMap[key] || 'send';
      %>
        <a href="<%= flatpaper_safe_url(href, 'href') %>" target="_blank" rel="noopener" aria-label="<%= name %>">
          <% if (entry.svg) { %>
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="1em" height="1em" fill="currentColor" class="lucide lucide-custom" aria-hidden="true"><%- entry.svg %></svg>
          <% } else { %>
            <%- partial('_partial/icons', { icon: iconName }) %>
          <% } %>
        </a>
      <% }) %>
      <% if (rss && rss.enable) { %>
        <a href="<%= flatpaper_safe_url(url_for(rss.path || 'atom.xml'), 'href') %>" aria-label="RSS feed" title="RSS">
          <%- partial('_partial/icons', { icon: 'rss' }) %>
        </a>
      <% } %>
    </div>
  </section>

  <% if (theme.nav && theme.nav.enable && theme.nav.menu && theme.nav.menu.length) { %>
    <section class="side-card brand-link-card" aria-label="<%= flatpaper_i18n('navigation.site_links') %>">
      <% (theme.nav.menu || []).forEach(function(group) { %>
        <div class="brand-link-group">
          <div class="brand-link-title"><%= group.title %></div>
          <div class="brand-link-list">
            <% (group.item || []).forEach(function(item) { %>
              <a href="<%= flatpaper_safe_url(item.link, 'href') %>" target="_blank" rel="noopener noreferrer">
                <% if (item.icon && item.icon.indexOf('http') === 0) { %>
                  <img src="<%= flatpaper_safe_url(item.icon, 'image') %>" alt="" class="nav-img-icon" aria-hidden="true" />
                <% } else if (item.icon) { %>
                  <%- partial('_partial/icons', { icon: item.icon }) %>
                <% } %>
                <span><%= item.name %></span>
              </a>
            <% }) %>
          </div>
        </div>
      <% }) %>
    </section>
  <% } %>

  <% if (is_post()) { %>
    <div class="post-sticky-stack">
      <section class="side-card toc-card">
        <header class="toc-card__head">
          <h2><%- partial('_partial/icons', { icon: 'table-of-contents' }) %><%= flatpaper_i18n('toc.title') %></h2>
          <button type="button" class="toc-toggle-all" data-action="toggle-toc" aria-pressed="false" aria-label="<%= flatpaper_i18n('toc.expand_all') %>" title="<%= flatpaper_i18n('toc.expand_all') %>">
            <%- partial('_partial/icons', { icon: 'chevron-down' }) %>
          </button>
        </header>
        <div class="toc-content">
          <% if (typeof toc === 'function') { %>
            <%- toc(page.content, { list_number: false, min_depth: 2, max_depth: 3 }) %>
          <% } else { %>
            <p><%= flatpaper_i18n('toc.empty') %></p>
          <% } %>
        </div>
      </section>
      <%- partial('_partial/latest-posts') %>
    </div>
  <% } else { %>
    <section class="side-card categories-card">
      <h2><%- partial('_partial/icons', { icon: 'folder' }) %><%= flatpaper_i18n('common.categories') %></h2>
      <% categories.slice(0, 6).forEach(function(category, index) { %>
        <a href="<%- url_for(category.path) %>">
          <span class="dot dot-<%= index % 4 %>"></span>
          <strong><%= category.name %></strong>
          <em><%= category.length %></em>
        </a>
      <% }) %>
    </section>

    <section class="side-card tag-card">
      <header class="tag-card__head">
        <h2><%- partial('_partial/icons', { icon: 'flame' }) %><%= flatpaper_i18n('sidebar.hot_tags') %></h2>
        <a class="tag-card__more" href="<%- url_for((config.tag_dir || 'tags') + '/') %>">
          <span><%= flatpaper_i18n('common.view_all') %></span>
          <%- partial('_partial/icons', { icon: 'arrow-right' }) %>
        </a>
      </header>
      <div class="tag-cloud">
        <%
          var hotTags = tags.slice().sort(function (a, b) { return (b.length || 0) - (a.length || 0); }).slice(0, 12);
        %>
        <% hotTags.forEach(function(tag, index) { %>
          <a class="tag-chip tag-chip-<%= index % 6 %>" href="<%- url_for(tag.path) %>"><%= tag.name %></a>
        <% }) %>
      </div>
    </section>
  <% } %>

  <%- partial('_partial/adsense-slot', { name: 'sidebar' }) %>
</aside>
