<%
var f = theme.footer || {};
var year = new Date().getFullYear();
// theme.footer.left/right intentionally allow raw HTML; the author name does
// not — escape it, and substitute via callbacks so "$&"-style sequences in
// config values can't trigger String.replace's special replacement patterns.
function escapeHTML(s) {
  return String(s).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}
var name = escapeHTML(config.author || 'FlatPaper');
var themeLink = '<a href="https://github.com/Homulilly/hexo-theme-flatpaper" target="_blank" rel="noopener">FlatPaper</a>';
function fill(tpl, fallback) {
  var s = (tpl == null) ? fallback : String(tpl);
  return s.replace(/\{year\}/g, year)
    .replace(/\{name\}/g, function () { return name; })
    .replace(/\{theme\}/g, function () { return themeLink; });
}
var left = fill(f.left, '© ' + year + ' ' + name);
var right = fill(f.right, 'Powered by Theme ' + themeLink);
%>
<footer class="site-footer">
  <span class="site-footer__left"><%- left %></span>
  <span class="site-footer__right"><%- right %></span>
</footer>
