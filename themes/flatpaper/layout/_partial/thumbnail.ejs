<%
var variant = index % 3;
var classes = ['paper-thumb', 'paper-thumb-' + variant];
var isLarge = typeof large !== 'undefined' && large;
var isSmall = typeof small !== 'undefined' && small;
var fallbackCovers = [
  '/images/cover/camera.webp',
  '/images/cover/mountain.webp',
  '/images/cover/notebook.webp',
  '/images/cover/port.webp',
  '/images/cover/snowman.webp'
];
if (isLarge) classes.push('paper-thumb--large');
if (isSmall) classes.push('paper-thumb--small');

// Resolve a real cover image from the post, if any.
var cover = '';
var fallbackCover = fallbackCovers[index % fallbackCovers.length];
var thumbSrc = '';
var thumbAlt = '';
if (typeof post !== 'undefined' && post) {
  cover = flatpaper_cover_info(post, fallbackCover);
  thumbAlt = post.title || '';
}
thumbSrc = cover ? cover.src : flatpaper_safe_url(url_for(fallbackCover), 'image');
// On homepage listings, avoid slow third-party cover images in post cards.
if (is_home() && cover && cover.raw && /^https?:\/\//i.test(cover.raw)) {
  thumbSrc = flatpaper_safe_url(url_for(fallbackCover), 'image');
  cover.isFallback = true;
}
if (thumbSrc) classes.push('paper-thumb--cover');
var isPriority = typeof priority !== 'undefined' && priority;
var isHomeFirstPage = is_home() && (!page.current || page.current === 1);
var imgLoading = (isPriority || isHomeFirstPage) ? 'eager' : 'lazy';
%>
<div class="<%= classes.join(' ') %>">
  <% if (thumbSrc) { %>
    <img class="paper-thumb__img" src="<%= thumbSrc %>" alt="<%= cover && !cover.isFallback ? thumbAlt : '' %>" loading="<%= imgLoading %>"<% if (isPriority) { %> fetchpriority="high"<% } %> decoding="async" referrerpolicy="no-referrer">
  <% } else { %>
    <div class="sun"></div>
    <div class="cloud cloud-a"></div>
    <div class="cloud cloud-b"></div>
    <div class="mountain mountain-a"></div>
    <div class="mountain mountain-b"></div>
    <div class="mountain mountain-c"></div>
    <% if (variant === 1) { %>
      <div class="screen"><i></i><i></i><i></i></div>
    <% } %>
    <% if (variant === 2) { %>
      <div class="camera"><i></i></div>
    <% } %>
  <% } %>
</div>
