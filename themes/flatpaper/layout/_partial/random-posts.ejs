<%
var randomLimit = theme.random_posts != null ? parseInt(theme.random_posts, 10) : 5;
if (isNaN(randomLimit)) randomLimit = 5;
var randomPoolLimit = parseInt(theme.random_posts_pool, 10);
if (isNaN(randomPoolLimit)) randomPoolLimit = 0; // 0 / unset = unlimited pool (documented)
var randomPool = flatpaper_sorted_posts()
  .filter(function (p) { return !page.path || p.path !== page.path; });
if (randomPoolLimit > 0) {
  randomPool = randomPool.slice(0, randomPoolLimit);
}
var randomPosts = randomLimit > 0 ? randomPool.slice(0, randomLimit) : [];
function jsonForScript(value) {
  return JSON.stringify(value).replace(/<\//g, '<\\/');
}
%>
<% if (randomPosts.length) { %>
  <section class="side-card recent-card" data-random-posts-limit="<%= randomLimit %>">
    <h2><%- partial('_partial/icons', { icon: 'shuffle' }) %><%= flatpaper_i18n('common.random_posts') %></h2>
    <ul class="recent-list js-random-posts">
      <% randomPosts.forEach(function (post) { %>
        <li>
          <a class="recent-item" href="<%- url_for(post.path) %>">
            <strong><%= post.title %></strong>
            <em><%= date(post.date, 'YYYY-MM-DD') %></em>
          </a>
        </li>
      <% }) %>
    </ul>
    <script type="application/json" class="js-random-posts-data">
    [
    <% randomPool.forEach(function (post, index, arr) { %>
      {
        "title": <%- jsonForScript(post.title || 'Untitled') %>,
        "url": <%- jsonForScript(url_for(post.path)) %>,
        "date": <%- jsonForScript(date(post.date, 'YYYY-MM-DD')) %>
      }<%= index < arr.length - 1 ? ',' : '' %>
    <% }) %>
    ]
    </script>
  </section>
<% } %>
