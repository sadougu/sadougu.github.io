<aside class="paper-sidebar paper-sidebar--left">
  <% if (is_home()) { %>
    <%
      var w = theme.welcome || {};
      var ctaText = w.cta_text || flatpaper_i18n('welcome.cta');
      var ctaLink = w.cta_link || (config.archive_dir || 'archives') + '/';
    %>
    <section class="welcome-card">
      <div class="welcome-thumb<%= w.image ? ' welcome-thumb--image' : '' %>" aria-hidden="true">
        <% if (w.image) { %>
          <img src="<%= flatpaper_safe_url(url_for(w.image), 'image') %>" alt="" loading="lazy" referrerpolicy="no-referrer">
        <% } else { %>
          <div class="sun"></div>
          <div class="cloud cloud-a"></div>
          <div class="cloud cloud-b"></div>
          <div class="mountain mountain-a"></div>
          <div class="mountain mountain-b"></div>
        <% } %>
      </div>
      <p class="hello"><span class="green-dot"></span><%= w.label || 'Hello!' %></p>
      <h1><%= w.title || flatpaper_i18n('welcome.title') %></h1>
      <p class="welcome-text"><%= w.text || flatpaper_i18n('welcome.text') %></p>
      <a class="welcome-cta" href="<%- url_for(ctaLink) %>"><span><%= ctaText %></span><%- partial('_partial/icons', { icon: 'arrow-right' }) %></a>
    </section>
  <% } %>
  <%- partial('_partial/random-posts') %>
</aside>
