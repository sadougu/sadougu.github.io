/* ============== SECTION HEAD ============== */
.section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 8px 4px 4px;
}

.section-head h2 {
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 0;
  font-size: 16px;
  font-weight: 700;
}

.section-head h2 .lucide {
  width: 16px;
  height: 16px;
  color: var(--color-accent);
}

.dark-mode .section-head h2 .lucide {
  color: var(--color-accent-muted);
}

.section-head a {
  color: var(--muted);
  font-size: 13px;
  transition: color 0.15s ease;
}

.section-head a:hover {
  color: var(--color-accent-strong);
}
