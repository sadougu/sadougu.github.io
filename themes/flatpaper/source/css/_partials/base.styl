* {
  box-sizing: border-box;
}

html {
  min-height: 100%;
  overflow-x: clip;
  background: var(--bg);
}

body {
  margin: 0;
  min-height: 100%;
  overflow-x: clip;
  color: var(--ink);
  font-family: var(--font-sans);
  font-size: 15px;
  line-height: 1.75;
  background: var(--bg);
}

.dark-mode body {
  background: var(--bg);
}

a {
  color: inherit;
  text-decoration: none;
}

/* Text selection follows the active accent (remapped via --color-accent). */
::selection {
  color: var(--ink);
  background: var(--color-accent-soft);
}
::-moz-selection {
  color: var(--ink);
  background: var(--color-accent-soft);
}

img {
  max-width: 100%;
  height: auto;
}

button {
  font-family: inherit;
}

.page-grain {
  position: fixed;
  inset: 0;
  z-index: -1;
  pointer-events: none;
  opacity: 0.3;
  background-image:
    linear-gradient(rgba(70, 50, 30, 0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(70, 50, 30, 0.025) 1px, transparent 1px);
  background-size: 18px 18px, 22px 22px;
  mask-image: linear-gradient(to bottom, transparent, #000 7%, #000 92%, transparent);
}

body.bg-style-grid {
  background-image:
    linear-gradient(rgba(89, 62, 30, 0.034) 1px, transparent 1px),
    linear-gradient(90deg, rgba(89, 62, 30, 0.023) 1px, transparent 1px);
  background-size: 34px 34px;
}
.dark-mode body.bg-style-grid {
  background-image:
    linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.017) 1px, transparent 1px);
}

body.bg-style-line {
  background-image: linear-gradient(rgba(89, 62, 30, 0.034) 1px, transparent 1px);
  background-size: 100% 34px;
}
.dark-mode body.bg-style-line {
  background-image: linear-gradient(rgba(255, 255, 255, 0.025) 1px, transparent 1px);
}

body.bg-style-cross {
  background-image: url("data:image/svg+xml,%3Csvg width='34' height='34' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 0H4V1H1V4H0Z' fill='rgba(89,62,30,0.05)'/%3E%3Crect x='30' y='0' width='4' height='1' fill='rgba(89,62,30,0.05)'/%3E%3Crect x='0' y='30' width='1' height='4' fill='rgba(89,62,30,0.05)'/%3E%3C/svg%3E");
  background-size: 34px 34px;
}
.dark-mode body.bg-style-cross {
  background-image: url("data:image/svg+xml,%3Csvg width='34' height='34' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M0 0H4V1H1V4H0Z' fill='rgba(255,255,255,0.04)'/%3E%3Crect x='30' y='0' width='4' height='1' fill='rgba(255,255,255,0.04)'/%3E%3Crect x='0' y='30' width='1' height='4' fill='rgba(255,255,255,0.04)'/%3E%3C/svg%3E");
}

body.bg-style-dotted {
  background-image: radial-gradient(rgba(70, 50, 30, 0.2) 1px, transparent 1px);
  background-size: 16px 16px;
  background-position: 0 0;
}
.dark-mode body.bg-style-dotted {
  background-image: radial-gradient(rgba(255, 255, 255, 0.15) 1px, transparent 1px);
}

@media (hover: hover) and (pointer: fine) {
  body.bg-style-grid,
  body.bg-style-line,
  body.bg-style-cross,
  body.bg-style-dotted {
    background-attachment: fixed;
  }
}

.site-header,
.paper-shell,
.site-footer {
  width: unquote('min(94vw, 1300px)');
  margin-inline: auto;
}
