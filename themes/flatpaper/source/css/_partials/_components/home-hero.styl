/* ============== HOME HERO ============== */
.home-hero {
  // Single source of truth for the "scrapbook paper" backdrop. .dark-mode swaps
  // the value below; the mobile image-reset reuses it too, so the gradient lives
  // in exactly one place per theme.
  --hero-paper:
    radial-gradient(circle at 16% 18%, rgba(255, 248, 224, 0.95) 0 11%, transparent 12%),
    radial-gradient(circle at 82% 16%, rgba(216, 232, 210, 0.85) 0 12%, transparent 13%),
    radial-gradient(circle at 78% 82%, rgba(245, 214, 224, 0.72) 0 13%, transparent 14%),
    linear-gradient(135deg, #fbf4df 0%, #f7f0dc 44%, #eaf2dd 100%);
  position: relative;
  display: grid;
  place-items: center;
  min-height: 100vh;
  min-height: 100dvh;
  padding: 36px unquote('max(18px, 5vw)');
  overflow: hidden;
  color: var(--ink);
  background: var(--hero-paper);
  isolation: isolate;
}

body.has-home-hero.is-hero-active::before {
  opacity: 0;
}

.home-hero--image {
  color: #fffdf6;
  background-image:
    linear-gradient(180deg, var(--hero-image-overlay-top, rgba(42, 33, 22, 0.22)), var(--hero-image-overlay-bottom, rgba(42, 33, 22, 0.58))),
    var(--hero-bg-image);
  background-size: cover;
  background-position: center;
}

.home-hero::before,
.home-hero::after,
.home-hero__grain {
  content: "";
  position: absolute;
  inset: 0;
  pointer-events: none;
}

.home-hero::before {
  z-index: -2;
  opacity: 0.42;
  background-image:
    linear-gradient(rgba(89, 62, 30, 0.08) 1px, transparent 1px),
    linear-gradient(90deg, rgba(89, 62, 30, 0.055) 1px, transparent 1px);
  background-size: 34px 34px, 34px 34px;
}

.home-hero::after {
  z-index: -1;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0));
  mix-blend-mode: multiply;
}

.home-hero--image::before {
  opacity: 0.24;
}

.home-hero--image::after {
  background: linear-gradient(180deg, rgba(0, 0, 0, 0), rgba(0, 0, 0, 0.16));
  mix-blend-mode: normal;
}

.home-hero__grain {
  z-index: 0;
  opacity: 0.28;
  background-image:
    repeating-radial-gradient(circle at 18% 18%, rgba(88, 62, 31, 0.11) 0 1px, transparent 1px 5px),
    repeating-linear-gradient(95deg, rgba(255, 255, 255, 0.28) 0 1px, transparent 1px 8px);
  mask-image: linear-gradient(to bottom, transparent, #000 8%, #000 92%, transparent);
}

.home-hero__tools {
  position: absolute;
  top: 22px;
  right: 22px;
  z-index: 5;
  display: flex;
  align-items: center;
  gap: 10px;
}

.home-hero__tools .home-hero__tool {
  color: var(--ink-soft);
  background: rgba(255, 253, 246, 0.72);
  border-color: rgba(177, 157, 117, 0.72);
  box-shadow: 0 8px 18px rgba(82, 64, 38, 0.12);
  backdrop-filter: blur(4px);
  -webkit-backdrop-filter: blur(4px);
}

.home-hero__tools .home-hero__tool:hover,
.home-hero__tools .home-hero__tool:focus-visible {
  color: var(--color-accent-strong);
  border-color: var(--color-accent);
  background: var(--color-accent-soft);
  outline: none;
}

.home-hero--image .home-hero__tools .home-hero__tool {
  color: #fffdf6;
  background: rgba(255, 253, 246, 0.14);
  border-color: rgba(255, 248, 236, 0.5);
  box-shadow: 0 10px 22px rgba(0, 0, 0, 0.2);
}

.home-hero--image .home-hero__tools .home-hero__tool:hover,
.home-hero--image .home-hero__tools .home-hero__tool:focus-visible {
  color: #2c3531;
  background: rgba(255, 253, 246, 0.92);
}

.home-hero__content {
  position: relative;
  z-index: 2;
  width: unquote('min(92vw, 720px)');
  display: grid;
  place-items: center;
}

.home-hero__profile {
  position: relative;
  width: 100%;
  display: grid;
  justify-items: center;
  padding: 46px 42px 34px;
  text-align: center;
}

.home-hero__profile::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: -1;
  border-radius: 8px 5px 10px 6px;
  background: rgba(255, 253, 246, 0.86);
  border: 1px dashed rgba(221, 208, 181, 0.9);
  box-shadow: 0 24px 70px rgba(82, 64, 38, 0.2);
  filter: url(#paper-edge);
  transform: rotate(-0.6deg);
}

.home-hero--image .home-hero__profile::before {
  background: rgba(43, 37, 30, 0.42);
  border-color: rgba(255, 248, 236, 0.45);
  box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
  backdrop-filter: blur(5px);
  -webkit-backdrop-filter: blur(5px);
}

.home-hero__profile::after {
  content: "";
  position: absolute;
  top: -12px;
  left: 50%;
  z-index: 1;
  width: 116px;
  height: 26px;
  border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
  background-color: var(--tape-yellow);
  background-image: var(--tape-stripes);
  box-shadow: 0 4px 12px rgba(82, 64, 38, 0.16);
  transform: translateX(-50%) rotate(2deg);
}

.home-hero__avatar {
  width: 112px;
  height: 112px;
  margin: 0 0 16px;
  box-shadow: 0 8px 24px rgba(82, 64, 38, 0.14);
}

.home-hero__eyebrow {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  margin: 0 0 8px;
  color: var(--color-accent-strong);
  font-size: 14px;
  font-weight: 800;
}

.home-hero--image .home-hero__eyebrow {
  color: #fff4bf;
}

.home-hero h1 {
  max-width: 13em;
  margin: 0;
  color: inherit;
  font-size: 64px;
  line-height: 1.05;
  letter-spacing: 0;
}

.home-hero__bio {
  max-width: 36em;
  margin: 18px 0 0;
  color: var(--ink-soft);
  font-size: 16px;
  line-height: 1.8;
}

.home-hero--image .home-hero__bio {
  color: rgba(255, 253, 246, 0.88);
}

.home-hero .home-hero__links {
  flex-wrap: wrap;
  gap: 10px 14px;
  width: 100%;
  max-width: 100%;
  margin: 16px auto -6px;
  padding: 6px 8px;
}

.home-hero .home-hero__links a {
  flex: 0 0 auto;
}

.home-hero--image .home-hero__links a {
  color: #fffdf6;
  background: rgba(255, 253, 246, 0.14);
  border-color: rgba(255, 248, 236, 0.45);
}

.home-hero--image .home-hero__links a:hover,
.home-hero--image .home-hero__links a:focus-visible {
  color: #2c3531;
  background: rgba(255, 253, 246, 0.92);
}

.home-hero__stickers {
  position: absolute;
  inset: 0;
  z-index: 3;
  pointer-events: none;
}

.hero-sticker {
  position: absolute;
  display: grid;
  place-items: center;
  min-width: 44px;
  min-height: 44px;
  padding: 0;
  border: 0;
  color: var(--ink);
  background: transparent;
  cursor: grab;
  pointer-events: auto;
  touch-action: none;
  user-select: none;
}

.hero-sticker:active,
.hero-sticker.is-dragging {
  cursor: grabbing;
}

.hero-sticker:focus-visible {
  outline: 2px dashed var(--color-accent);
  outline-offset: 4px;
}

.hero-sticker span {
  display: grid;
  place-items: center;
  width: 100%;
  height: 100%;
  font-weight: 800;
  line-height: 1;
}

.hero-sticker--note {
  top: 67%;
  left: 13%;
  width: 108px;
  min-height: 82px;
  padding: 18px 14px 12px;
  color: #6a5430;
  background: #fff1a8;
  box-shadow: 5px 7px 0 rgba(82, 64, 38, 0.1);
  transform: rotate(-6deg);
}

.hero-sticker--note::before {
  content: "";
  position: absolute;
  top: -8px;
  left: 50%;
  width: 48px;
  height: 16px;
  background-color: var(--tape-green);
  background-image: var(--tape-stripes);
  transform: translateX(-50%) rotate(4deg);
}

.hero-sticker--note span {
  font-size: 13px;
  line-height: 1.35;
}

.hero-sticker--custom {
  width: var(--sticker-size, 96px);
  min-width: 0;
  min-height: 0;
  padding: 0;
  border: 0;
  border-radius: 8px;
  background: transparent;
  filter: drop-shadow(0 8px 12px rgba(82, 64, 38, 0.18));
  text-decoration: none;
}

.hero-sticker--custom img {
  display: block;
  width: 100%;
  height: auto;
  max-height: 150px;
  object-fit: contain;
  pointer-events: none;
}

.hero-sticker--custom:hover,
.hero-sticker--custom:focus-visible {
  transform: translateY(-2px) rotate(-2deg);
  filter: drop-shadow(0 11px 16px rgba(82, 64, 38, 0.22));
}

.hero-sticker--custom-0 {
  top: 24%;
  left: 17%;
  transform: rotate(-8deg);
}

.hero-sticker--custom-1 {
  top: 15%;
  right: 8%;
  transform: rotate(7deg);
}

.hero-sticker--custom-2 {
  right: 16%;
  bottom: 10%;
  transform: rotate(-5deg);
}

.hero-sticker--custom-3 {
  left: 5%;
  bottom: 13%;
  transform: rotate(6deg);
}

.hero-sticker--custom-4 {
  top: 47%;
  right: 5%;
  transform: rotate(-10deg);
}

.home-hero__arrow {
  position: absolute;
  left: 50%;
  bottom: 22px;
  z-index: 4;
  display: grid;
  place-items: center;
  width: 42px;
  height: 42px;
  color: var(--ink-soft);
  background: rgba(255, 253, 246, 0.68);
  border: 1px dashed var(--dash);
  border-radius: 50%;
  box-shadow: var(--paper-shadow);
  transform: translateX(-50%);
  animation: home-hero-arrow-bounce 1.35s ease-in-out infinite;
  transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
}

.home-hero__arrow:hover,
.home-hero__arrow:focus-visible {
  color: var(--color-accent-strong);
  background: var(--color-accent-soft);
  border-color: var(--color-accent);
  outline: none;
}

.home-hero--image .home-hero__arrow {
  color: #fffdf6;
  background: rgba(255, 253, 246, 0.14);
  border-color: rgba(255, 248, 236, 0.52);
}

.home-hero--image .home-hero__arrow:hover,
.home-hero--image .home-hero__arrow:focus-visible {
  color: #2c3531;
  background: rgba(255, 253, 246, 0.94);
}

.home-hero__arrow .lucide {
  width: 20px;
  height: 20px;
}

@keyframes home-hero-arrow-bounce {
  0%, 100% {
    transform: translate(-50%, 0);
  }
  50% {
    transform: translate(-50%, 8px);
  }
}

.hero-sticker-confirm {
  position: absolute;
  z-index: 8;
  width: 190px;
  padding: 16px 14px 12px;
  color: var(--ink);
  background: var(--paper);
  border: 1px dashed var(--dash);
  border-radius: 7px 5px 8px 4px;
  box-shadow: 0 12px 28px rgba(82, 64, 38, 0.18);
  filter: url(#paper-edge);
}

.hero-sticker-confirm::before {
  content: "";
  position: absolute;
  top: -8px;
  left: 50%;
  width: 54px;
  height: 15px;
  background-color: var(--tape-pink);
  background-image: var(--tape-stripes);
  box-shadow: 0 2px 6px rgba(82, 64, 38, 0.12);
  transform: translateX(-50%) rotate(-4deg);
}

.hero-sticker-confirm p {
  margin: 0 0 10px;
  color: var(--ink-soft);
  font-size: 13px;
  font-weight: 800;
  line-height: 1.35;
  text-align: center;
}

.hero-sticker-confirm__actions {
  display: flex;
  justify-content: center;
  gap: 10px;
}

.hero-sticker-confirm button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 56px;
  min-height: 32px;
  padding: 7px 12px;
  border: 1px dashed rgba(106, 84, 48, 0.28);
  border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
  color: #58472a;
  background-color: var(--tape-yellow);
  background-image: var(--tape-stripes);
  box-shadow: 2px 3px 0 rgba(82, 64, 38, 0.12);
  font: inherit;
  font-size: 12px;
  font-weight: 800;
  cursor: pointer;
  transform: rotate(-2deg);
  transition: color 0.2s ease, background-color 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
}

.hero-sticker-confirm button.hero-sticker-confirm__visit {
  color: #395238;
  background-color: var(--tape-green);
}

.hero-sticker-confirm button.hero-sticker-confirm__cancel {
  color: #6b3f4c;
  background-color: var(--tape-pink);
  transform: rotate(2deg);
}

.hero-sticker-confirm button:hover,
.hero-sticker-confirm button:focus-visible {
  color: var(--ink);
  border-color: var(--color-accent);
  background-color: var(--color-accent-soft);
  box-shadow: 3px 5px 0 rgba(82, 64, 38, 0.14);
  outline: none;
  transform: rotate(0deg) translateY(-2px);
}

.hero-sticker-confirm button.hero-sticker-confirm__cancel:hover,
.hero-sticker-confirm button.hero-sticker-confirm__cancel:focus-visible {
  color: #6b3f4c;
  border-color: rgba(154, 86, 101, 0.46);
  background-color: var(--tape-pink);
}

.dark-mode .home-hero {
  // Swap the paper backdrop for the dark palette; .home-hero (and the mobile
  // image-reset) already paint via var(--hero-paper). In --image mode the photo
  // overrides background-image, so this var simply goes unused there.
  --hero-paper:
    radial-gradient(circle at 16% 18%, rgba(70, 63, 45, 0.9) 0 11%, transparent 12%),
    radial-gradient(circle at 82% 16%, rgba(45, 68, 55, 0.86) 0 12%, transparent 13%),
    radial-gradient(circle at 78% 82%, rgba(74, 44, 53, 0.72) 0 13%, transparent 14%),
    linear-gradient(135deg, #22262b 0%, #1d2027 48%, #243027 100%);
}

.dark-mode .home-hero__profile::before {
  background: rgba(35, 39, 50, 0.9);
  border-color: var(--dash);
}

.dark-mode .home-hero:not(.home-hero--image) .home-hero__tools .home-hero__tool {
  color: var(--ink-soft);
  background: rgba(35, 39, 50, 0.78);
  border-color: var(--dash);
  box-shadow: 0 10px 22px rgba(0, 0, 0, 0.28);
}

.dark-mode .home-hero:not(.home-hero--image) .home-hero__tools .home-hero__tool:hover,
.dark-mode .home-hero:not(.home-hero--image) .home-hero__tools .home-hero__tool:focus-visible {
  color: var(--color-accent-muted);
  background: var(--color-accent-soft);
  border-color: var(--color-accent);
}

.dark-mode .home-hero:not(.home-hero--image) .home-hero__arrow {
  color: var(--ink-soft);
  background: rgba(35, 39, 50, 0.78);
  border-color: var(--dash);
  box-shadow: 0 10px 22px rgba(0, 0, 0, 0.28);
}

.dark-mode .home-hero:not(.home-hero--image) .home-hero__arrow:hover,
.dark-mode .home-hero:not(.home-hero--image) .home-hero__arrow:focus-visible {
  color: var(--color-accent-muted);
  background: var(--color-accent-soft);
  border-color: var(--color-accent);
}

.dark-mode .home-hero__bio,
.dark-mode .home-hero__links a {
  color: var(--ink-soft);
}

.dark-mode .hero-sticker--note {
  color: #42331e;
}

.dark-mode .hero-sticker--custom {
  filter: drop-shadow(0 8px 12px rgba(0, 0, 0, 0.34));
}

.dark-mode .hero-sticker-confirm button {
  color: #cbbba5;
}

.dark-mode .hero-sticker-confirm button.hero-sticker-confirm__visit {
  color: #add0af;
}

.dark-mode .hero-sticker-confirm button.hero-sticker-confirm__cancel {
  color: #df9eaf;
}

.dark-mode .hero-sticker-confirm button.hero-sticker-confirm__cancel:hover,
.dark-mode .hero-sticker-confirm button.hero-sticker-confirm__cancel:focus-visible {
  color: #f1c9d0;
  border-color: rgba(232, 168, 158, 0.42);
  background-color: var(--tape-pink);
}

@media (max-width: 960px) {
  .home-hero h1 {
    font-size: 52px;
  }
}

@media (max-width: 760px) {
  .home-hero {
    padding: 24px 16px;
  }

  .home-hero--image {
    // On phones the configured photo is dropped for legibility — fall back to the
    // same paper backdrop as the no-image hero (dark-aware via var(--hero-paper)).
    color: var(--ink);
    background: var(--hero-paper);
    background-size: auto;
    background-position: center;
  }

  .home-hero--image::before {
    opacity: 0.42;
  }

  .home-hero--image::after {
    background: linear-gradient(180deg, rgba(255, 255, 255, 0.35), rgba(255, 255, 255, 0));
    mix-blend-mode: multiply;
  }

  .home-hero__tools {
    top: 16px;
    right: 16px;
    gap: 8px;
  }

  .home-hero__profile {
    padding: 38px 22px 28px;
  }

  .home-hero--image .home-hero__profile::before {
    background: rgba(255, 253, 246, 0.86);
    border-color: rgba(221, 208, 181, 0.9);
    box-shadow: 0 24px 70px rgba(82, 64, 38, 0.2);
    backdrop-filter: none;
    -webkit-backdrop-filter: none;
  }

  .home-hero__avatar {
    width: 92px;
    height: 92px;
  }

  .home-hero--image .home-hero__eyebrow {
    color: var(--color-accent-strong);
  }

  .home-hero h1 {
    font-size: 36px;
  }

  .home-hero__bio {
    font-size: 14px;
  }

  .home-hero--image .home-hero__bio {
    color: var(--ink-soft);
  }

  .home-hero--image .home-hero__links a {
    color: var(--muted);
    background: transparent;
    border-color: var(--line);
  }

  .home-hero--image .home-hero__links a:hover,
  .home-hero--image .home-hero__links a:focus-visible {
    color: var(--color-accent-strong);
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
  }

  .home-hero--image .home-hero__tools .home-hero__tool,
  .home-hero--image .home-hero__arrow {
    color: var(--ink-soft);
    background: rgba(255, 253, 246, 0.72);
    border-color: rgba(177, 157, 117, 0.72);
    box-shadow: 0 8px 18px rgba(82, 64, 38, 0.12);
  }

  .home-hero--image .home-hero__tools .home-hero__tool:hover,
  .home-hero--image .home-hero__tools .home-hero__tool:focus-visible,
  .home-hero--image .home-hero__arrow:hover,
  .home-hero--image .home-hero__arrow:focus-visible {
    color: var(--color-accent-strong);
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
  }

  .hero-sticker--note {
    left: 4%;
    top: 72%;
  }

  .hero-sticker--custom {
    width: var(--sticker-size, 82px);
  }

  .hero-sticker--custom-0,
  .hero-sticker--custom-3 {
    left: 2%;
  }

  .hero-sticker--custom-1,
  .hero-sticker--custom-2,
  .hero-sticker--custom-4 {
    right: 2%;
  }

  .hero-sticker--custom-4 {
    top: 9%;
  }

  .dark-mode .home-hero--image .home-hero__profile::before {
    background: rgba(35, 39, 50, 0.9);
    border-color: var(--dash);
  }

  .dark-mode .home-hero--image .home-hero__tools .home-hero__tool,
  .dark-mode .home-hero--image .home-hero__arrow {
    color: var(--ink-soft);
    background: rgba(35, 39, 50, 0.78);
    border-color: var(--dash);
    box-shadow: 0 10px 22px rgba(0, 0, 0, 0.28);
  }

  .dark-mode .home-hero--image .home-hero__tools .home-hero__tool:hover,
  .dark-mode .home-hero--image .home-hero__tools .home-hero__tool:focus-visible,
  .dark-mode .home-hero--image .home-hero__arrow:hover,
  .dark-mode .home-hero--image .home-hero__arrow:focus-visible {
    color: var(--color-accent-muted);
    background: var(--color-accent-soft);
    border-color: var(--color-accent);
  }
}

@media (prefers-reduced-motion: reduce) {
  .home-hero__links a {
    transition: none;
  }

  .home-hero__arrow {
    animation: none;
  }
}
