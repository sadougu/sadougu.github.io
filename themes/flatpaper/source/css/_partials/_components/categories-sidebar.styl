/* ============== CATEGORIES (sidebar) ============== */
.categories-card::before {
  content: "";
  position: absolute;
  top: -10px;
  left: 50%;
  z-index: 2;
  width: 70px;
  height: 20px;
  background-color: var(--tape-blue);
  background-image: var(--tape-stripes);
  filter: saturate(0.9);
  transform: translateX(-50%);
}

.categories-card a {
  display: grid;
  grid-template-columns: 12px 1fr auto;
  gap: 10px;
  align-items: center;
  padding: 9px 0;
  border-bottom: 1px dashed var(--line);
  font-size: 14px;
  transition: color 0.18s ease, transform 0.18s ease;
}

.categories-card a:last-child {
  border-bottom: 0;
}

.categories-card strong {
  font-weight: 600;
  transition: color 0.18s ease;
}

.categories-card em,
.archive-item em,
.taxonomy-card em {
  color: var(--muted);
  font-style: normal;
  font-size: 13px;
}

.dot {
  width: 9px;
  height: 9px;
  border-radius: 255px 15px 225px 15px/15px 225px 15px 255px;
  background: var(--color-accent);
  transform: rotate(-10deg);
  transition: transform 0.18s ease, box-shadow 0.18s ease;
}

.dot-0 { background: var(--color-accent); }
.dot-1 { background: var(--blue); }
.dot-2 { background: var(--orange); }
.dot-3 { background: var(--violet); }

.categories-card a:hover {
  color: var(--color-accent-strong);
  transform: translateX(3px);
}

.categories-card a:hover em {
  color: var(--color-accent-strong);
}

.categories-card a:hover .dot {
  transform: rotate(5deg) scale(1.24);
  box-shadow: 0 0 0 4px rgba(111, 166, 124, 0.14);
}

.dark-mode .categories-card a:hover {
  color: var(--color-accent-muted);
}

.dark-mode .categories-card a:hover em {
  color: var(--color-accent-muted);
}
