/* ============== TABS BLOCK ============== */
.flatpaper-tabs {
  position: relative;
  margin: 32px 0;
  z-index: 1;
  border: 1px solid var(--line);
  border-radius: 6px;
  background: var(--paper);
  box-shadow: 2px 4px 10px rgba(0,0,0,0.03);
}

.flatpaper-tabs__intro {
  padding: 12px 16px;
  border-bottom: 1px dashed var(--line);
  color: var(--ink-soft);
  font-size: 13px;
  line-height: 1.7;
}

.flatpaper-tabs__intro > :first-child { margin-top: 0; }
.flatpaper-tabs__intro > :last-child { margin-bottom: 0; }

.flatpaper-tabs__nav {
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 12px 12px 0 12px;
  background: var(--bg);
  border-radius: 6px 6px 0 0;
  border-bottom: 1px solid var(--line);
  position: relative;
  z-index: 2;
}

.flatpaper-tabs__nav-item {
  appearance: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 90px;
  position: relative;
  background: var(--bg);
  border: 1px solid var(--line);
  border-radius: 4px 4px 0 0;
  padding: 14px 24px 10px 24px;
  margin: 0;
  color: var(--ink);
  font: inherit;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.2px;
  cursor: pointer;
  overflow: hidden;
  transition: all 0.2s;
}

.flatpaper-tabs__nav-item:hover:not(.is-active) {
  color: var(--ink);
  background-color: unquote('color-mix(in srgb, var(--dash) 30%, transparent)');
}

/* 用伪元素模拟贴在标签顶部的彩色纸胶带 */
.flatpaper-tabs__nav-item::before {
  content: '';
  position: absolute;
  top: -2px;
  left: -5%;
  right: -5%;
  height: 12px;
  background-color: var(--tape-pink, #f8a5c2);
  opacity: 0.8;
  transform: rotate(-1.5deg);
}
.flatpaper-tabs__nav-item:nth-child(2n)::before {
  background-color: var(--tape-blue, #778beb);
  transform: rotate(1deg);
}
.flatpaper-tabs__nav-item:nth-child(3n)::before {
  background-color: var(--tape-green, #63cdda);
  transform: rotate(-1deg);
}
.flatpaper-tabs__nav-item:nth-child(4n)::before {
  background-color: var(--tape-yellow, #f7d794);
  transform: rotate(1.5deg);
}

.flatpaper-tabs__nav-item.is-active {
  background: var(--paper);
  border-bottom-color: var(--paper);
  margin-bottom: -1px; /* 往下偏移1px，与底部内容区背景融合 */
  color: var(--color-accent-strong);
  font-weight: 700;
  z-index: 3;
}
.dark-mode .flatpaper-tabs__nav-item.is-active {
  color: var(--color-accent-muted);
}

.flatpaper-tabs__nav-item.is-active::before {
  height: 14px;
  opacity: 1;
}

.flatpaper-tabs__panels {
  position: relative;
  z-index: 1;
  padding: 20px;
}

.flatpaper-tabs__panel > :first-child { margin-top: 0; }
.flatpaper-tabs__panel > :last-child { margin-bottom: 0; }
.flatpaper-tabs__panel[hidden] { display: none; }
