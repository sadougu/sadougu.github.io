/* ============== FRIENDS / LINK PAGE ============== */
.friends-page {
  padding-bottom: 32px;
}

.friends-subtitle {
  margin: 8px 0 0;
  color: var(--muted);
  font-size: 13px;
}

.friends-page .friends-intro {
  margin-top: 32px;
  padding: 32px 0 4px;
  font-size: 14px;
  border-top: 1px dashed var(--line);
}

.friends-page .friends-intro > :first-child { margin-top: 0; }
.friends-intro > :last-child { margin-bottom: 0; }

.friends-group {
  margin-top: 28px;
}

.friends-group__head {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8px 14px;
  margin-bottom: 16px;
}

.friends-group__head h2 {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin: 0;
  font-size: 18px;
  font-weight: 700;
}

.friends-group__desc {
  color: var(--muted);
  font-size: 12px;
}

.friends-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 14px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.friend-card {
  position: relative;
}

.friend-card__rss {
  position: absolute;
  top: 8px;
  right: 8px;
  z-index: 2;
  display: inline-grid;
  place-items: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  color: var(--muted);
  background: transparent;
  transition: color 0.25s ease, background 0.25s ease, transform 0.25s ease;
}

.friend-card__rss .lucide {
  width: 13px;
  height: 13px;
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* Signal-wave ring that pulses out when the card is hovered */
.friend-card__rss::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1.5px solid currentColor;
  opacity: 0;
  pointer-events: none;
}

.friend-card:hover .friend-card__rss {
  color: var(--color-accent-strong);
  background: var(--color-accent-soft);
}

.friend-card:hover .friend-card__rss .lucide {
  animation: flatpaper-rss-wiggle 0.7s ease;
}

.friend-card:hover .friend-card__rss::before {
  animation: flatpaper-rss-pulse 1.1s ease-out;
}

.friend-card__rss:hover {
  transform: scale(1.1);
}

@keyframes flatpaper-rss-wiggle {
  0%   { transform: rotate(0)    scale(1); }
  25%  { transform: rotate(-8deg) scale(1.08); }
  50%  { transform: rotate(6deg)  scale(1.12); }
  75%  { transform: rotate(-3deg) scale(1.06); }
  100% { transform: rotate(0)    scale(1); }
}

@keyframes flatpaper-rss-pulse {
  0%   { opacity: 0.45; transform: scale(1); }
  100% { opacity: 0;    transform: scale(1.9); }
}

.dark-mode .friend-card:hover .friend-card__rss {
  color: var(--color-accent-muted);
  background: var(--color-accent-soft);
}

.friend-card__link {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border: 1px dashed var(--dash);
  border-radius: 12px;
  background: var(--paper);
  color: var(--ink);
  text-decoration: none;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.friend-card__link:hover {
  transform: translateY(-3px);
  border-color: var(--color-accent);
  box-shadow: var(--small-shadow);
}

.friend-card__avatar {
  flex-shrink: 0;
  display: inline-grid;
  place-items: center;
  width: 44px;
  height: 44px;
  border-radius: 50%;
  object-fit: cover;
  background: var(--color-accent-soft);
  color: var(--color-accent-strong);
  font-weight: 700;
  font-size: 18px;
}

img.friend-card__avatar {
  background: transparent;
}

.dark-mode .friend-card__avatar--text {
  color: var(--color-accent-muted);
}

.friend-card__body {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.friend-card__name {
  font-size: 14px;
  font-weight: 700;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.friend-card__link:hover .friend-card__name {
  color: var(--color-accent-strong);
}

.dark-mode .friend-card__link:hover .friend-card__name {
  color: var(--color-accent-muted);
}

.friend-card__desc {
  color: var(--muted);
  font-size: 12px;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}



/* Shown when a friends group has no entries. */
.friends-empty {
  margin: 24px 0 8px;
  text-align: center;
  color: var(--muted);
  font-size: 13px;
}

/* --- Tape Style Friend Cards --- */
.friend-card--tape {
  z-index: 1;
  --friend-tape-top: -8px;
  --friend-tape-left: 25%;
  --friend-tape-right: auto;
  --friend-tape-width: 38px;
  --friend-tape-height: 15px;
  --friend-tape-rotate: -6deg;
  --friend-tape-color: var(--tape-yellow);
}

.friend-card--tape:hover {
  z-index: 10;
}

.friend-card--tape .friend-card__link {
  border: 1px dashed var(--dash);
  border-radius: 2px;
  background: var(--paper-warm);
  box-shadow: var(--soft-shadow);
  transform-origin: center top;
}

.friend-card--tape:nth-child(even) .friend-card__link {
  transform: rotate(0.6deg);
}

.friend-card--tape:nth-child(odd) .friend-card__link {
  transform: rotate(-0.6deg);
}

.friend-card--tape .friend-card__link:hover {
  transform: translateY(-4px) scale(1.02) rotate(0deg);
  border-color: var(--color-accent);
  box-shadow: 0 10px 22px rgba(82, 64, 38, 0.15);
}

.dark-mode .friend-card--tape .friend-card__link:hover {
  box-shadow: 0 10px 22px rgba(0, 0, 0, 0.4);
}

/* Scrapbook tape for tape-style cards */
.friend-card--tape::after {
  content: "";
  position: absolute;
  top: var(--friend-tape-top);
  left: var(--friend-tape-left);
  right: var(--friend-tape-right);
  transform: rotate(var(--friend-tape-rotate));
  transform-origin: center;
  width: var(--friend-tape-width);
  height: var(--friend-tape-height);
  background-color: var(--friend-tape-color);
  background-image: var(--tape-stripes);
  border-radius: 2px;
  box-shadow: 0 2px 5px rgba(82, 64, 38, 0.10);
  opacity: 0.92;
  z-index: 1;
  pointer-events: none;
  transition: transform 0.22s ease;
}

/* Lift the tape in step with the card on hover. */
.friend-card--tape:hover::after {
  transform: translateY(-4px) rotate(var(--friend-tape-rotate));
}

.friend-card--tape:nth-child(even)::after {
  --friend-tape-top: -8px;
  --friend-tape-left: auto;
  --friend-tape-right: 25%;
  --friend-tape-rotate: 6deg;
  --friend-tape-color: var(--tape-blue);
}

.friend-card--tape:nth-child(4n+1)::after {
  --friend-tape-color: var(--tape-yellow);
}

.friend-card--tape:nth-child(4n+2)::after {
  --friend-tape-color: var(--tape-blue);
}

.friend-card--tape:nth-child(4n+3)::after {
  --friend-tape-top: -7px;
  --friend-tape-width: 34px;
  --friend-tape-rotate: -4deg;
  --friend-tape-color: var(--tape-pink);
}

.friend-card--tape:nth-child(4n)::after {
  --friend-tape-top: -7px;
  --friend-tape-width: 36px;
  --friend-tape-rotate: 4deg;
  --friend-tape-color: var(--tape-green);
}

.tape-disabled .friend-card--tape::after {
  display: none;
}
