/* ============== FRIENDS / LINK PAGE ============== */
.friends-page {
  padding-bottom: 32px;
}

.friends-subtitle {
  margin: 8px 0 0;
  color: var(--muted);
  font-size: 13px;
}

.friends-page .friends-intro {
  margin-top: 32px;
  padding: 32px 0 4px;
  font-size: 14px;
  border-top: 1px dashed var(--line);
}

.friends-page .friends-intro > :first-child { margin-top: 0; }
.friends-intro > :last-child { margin-bottom: 0; }

.friends-group {
  margin-top: 28px;
}

.friends-group__head {
  display: flex;
  align-items: baseline;
  flex-wrap: wrap;
  gap: 8px 14px;
  margin-bottom: 16px;
}

.friends-group__head h2 {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  margin: 0;
  font-size: 18px;
  font-weight: 700;
}

.friends-group__desc {
  color: var(--muted);
  font-size: 12px;
}

.friends-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
  gap: 14px;
  margin: 0;
  padding: 0;
  list-style: none;
}

.friend-card {
  position: relative;
}

.friend-card__rss {
  position: absolute;
  top: 8px;
  right: 8px;
  z-index: 2;
  display: inline-grid;
  place-items: center;
  width: 26px;
  height: 26px;
  border-radius: 50%;
  color: var(--muted);
  background: transparent;
  transition: color 0.25s ease, background 0.25s ease, transform 0.25s ease;
}

.friend-card__rss .lucide {
  width: 13px;
  height: 13px;
  transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* Signal-wave ring that pulses out when the card is hovered */
.friend-card__rss::before {
  content: "";
  position: absolute;
  inset: 0;
  border-radius: 50%;
  border: 1.5px solid currentColor;
  opacity: 0;
  pointer-events: none;
}

.friend-card:hover .friend-card__rss {
  color: var(--color-accent-strong);
  background: var(--color-accent-soft);
}

.friend-card:hover .friend-card__rss .lucide {
  animation: flatpaper-rss-wiggle 0.7s ease;
}

.friend-card:hover .friend-card__rss::before {
  animation: flatpaper-rss-pulse 1.1s ease-out;
}

.friend-card__rss:hover {
  transform: scale(1.1);
}

@keyframes flatpaper-rss-wiggle {
  0%   { transform: rotate(0)    scale(1); }
  25%  { transform: rotate(-8deg) scale(1.08); }
  50%  { transform: rotate(6deg)  scale(1.12); }
  75%  { transform: rotate(-3deg) scale(1.06); }
  100% { transform: rotate(0)    scale(1); }
}

@keyframes flatpaper-rss-pulse {
  0%   { opacity: 0.45; transform: scale(1); }
  100% { opacity: 0;    transform: scale(1.9); }
}

.dark-mode .friend-card:hover .friend-card__rss {
  color: var(--color-accent-muted);
  background: var(--color-accent-soft);
}

.friend-card__link {
  display: flex;
  align-items: center;
  gap: 12px;
  padding: 12px;
  border: 1px dashed var(--dash);
  border-radius: 12px;
  background: var(--paper);
  color: var(--ink);
  text-decoration: none;
  transition: transform 0.22s ease, box-shadow 0.22s ease, border-color 0.22s ease;
}

.friend-card__link:hover {
  transform: translateY(-3px);
  border-color: var(--color-accent);
  box-shadow: var(--small-shadow);
}

.friend-card__avatar-wrap {
  flex-shrink: 0;
  display: inline-grid;
  place-items: center;
  width: 58px;
  height: 58px;
  margin-top: 2px;
  border: 1px solid rgba(82, 64, 38, 0.12);
  border-radius: 8px;
  background: var(--paper-solid);
  box-shadow: 2px 3px 0 rgba(82, 64, 38, 0.08);
  transform: rotate(-2deg);
  transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
}

.friend-card__link:hover .friend-card__avatar-wrap {
  border-color: var(--color-accent);
  box-shadow: 3px 5px 0 rgba(82, 64, 38, 0.1);
  transform: rotate(0deg) translateY(-1px);
}

.friend-card__avatar {
  display: inline-grid;
  place-items: center;
  width: 50px;
  height: 50px;
  border-radius: 6px;
  object-fit: cover;
  background: var(--color-accent-soft);
  color: var(--color-accent-strong);
  font-size: 18px;
  font-weight: 800;
}

img.friend-card__avatar {
  background: transparent;
}

.dark-mode .friend-card__avatar-wrap {
  border-color: rgba(225, 230, 245, 0.12);
  background: var(--paper-warm);
  box-shadow: 2px 3px 0 rgba(0, 0, 0, 0.18);
}

.dark-mode .friend-card__link:hover .friend-card__avatar-wrap {
  border-color: var(--color-accent-muted);
  box-shadow: 3px 5px 0 rgba(0, 0, 0, 0.22);
}

.dark-mode .friend-card__avatar--text {
  color: var(--color-accent-muted);
}

.friend-card__body {
  min-width: 0;
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 2px;
}

.friend-card__name {
  font-size: 14px;
  font-weight: 700;
  line-height: 1.4;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.friend-card__link:hover .friend-card__name {
  color: var(--color-accent-strong);
}

.dark-mode .friend-card__link:hover .friend-card__name {
  color: var(--color-accent-muted);
}

.friend-card__desc {
  color: var(--muted);
  font-size: 12px;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  overflow: hidden;
}



/* Shown when a friends group has no entries. */
.friends-empty {
  margin: 24px 0 8px;
  text-align: center;
  color: var(--muted);
  font-size: 13px;
}

/* --- Tape Style Friend Cards --- */
.friend-card--tape {
  z-index: 1;
  --feed-tilt: -0.25deg;
  --feed-tape: var(--tape-yellow);
  --feed-tab: var(--tape-green);
}

.friend-card--tape:nth-child(4n+2) {
  --feed-tilt: 0.22deg;
  --feed-tape: var(--tape-pink);
  --feed-tab: var(--tape-blue);
}

.friend-card--tape:nth-child(4n+3) {
  --feed-tilt: -0.12deg;
  --feed-tape: var(--tape-green);
  --feed-tab: var(--tape-yellow);
}

.friend-card--tape:nth-child(4n+4) {
  --feed-tilt: 0.3deg;
  --feed-tape: var(--tape-blue);
  --feed-tab: var(--tape-pink);
}

.friend-card--tape:hover {
  z-index: 10;
}

.friend-card--tape .friend-card__link {
  border: 1px dashed var(--dash);
  border-radius: 8px;
  background:
    linear-gradient(90deg, transparent 0, transparent 54px, rgba(221, 208, 181, 0.42) 54px, rgba(221, 208, 181, 0.42) 55px, transparent 55px),
    repeating-linear-gradient(180deg, transparent 0 27px, rgba(221, 208, 181, 0.18) 27px 28px),
    var(--paper);
  box-shadow: 4px 5px 0 rgba(82, 64, 38, 0.08), var(--soft-shadow);
  isolation: isolate;
  transform: rotate(var(--feed-tilt));
  transition: transform 0.22s ease, border-color 0.22s ease, box-shadow 0.22s ease;
}

.friend-card--tape .friend-card__link:hover {
  transform: translateY(-3px) rotate(0deg);
  border-color: var(--color-accent);
  box-shadow: 6px 8px 0 rgba(82, 64, 38, 0.1), var(--small-shadow);
}

.dark-mode .friend-card--tape .friend-card__link {
  background:
    linear-gradient(90deg, transparent 0, transparent 54px, rgba(225, 230, 245, 0.1) 54px, rgba(225, 230, 245, 0.1) 55px, transparent 55px),
    repeating-linear-gradient(180deg, transparent 0 27px, rgba(225, 230, 245, 0.04) 27px 28px),
    var(--paper);
  box-shadow: 4px 5px 0 rgba(0, 0, 0, 0.18), var(--soft-shadow);
}

.dark-mode .friend-card--tape .friend-card__link:hover {
  box-shadow: 6px 8px 0 rgba(0, 0, 0, 0.25), var(--small-shadow);
}

/* Tape */
.friend-card--tape .friend-card__link::before {
  content: "";
  position: absolute;
  top: -8px;
  left: 22px;
  z-index: 2;
  width: 38px;
  height: 15px;
  background-color: var(--feed-tape);
  background-image: var(--tape-stripes);
  box-shadow: 0 3px 8px rgba(82, 64, 38, 0.12);
  filter: saturate(0.92);
  transform: rotate(-3deg);
  pointer-events: none;
}

/* Tab */
.friend-card--tape .friend-card__link::after {
  content: "";
  position: absolute;
  top: 16px;
  right: -6px;
  z-index: -1;
  width: 6px;
  height: 48px;
  border: 1px dashed rgba(82, 64, 38, 0.12);
  border-left: 0;
  border-radius: 0 6px 6px 0;
  background: var(--feed-tab);
  box-shadow: 2px 3px 0 rgba(82, 64, 38, 0.08);
  transition: width 0.25s cubic-bezier(0.34, 1.56, 0.64, 1), right 0.25s cubic-bezier(0.34, 1.56, 0.64, 1);
  pointer-events: none;
}

.friend-card--tape .friend-card__link:hover::after {
  right: -12px;
  width: 12px;
}

.dark-mode .friend-card--tape .friend-card__link::before {
  box-shadow: 0 3px 8px rgba(0, 0, 0, 0.24);
}

.dark-mode .friend-card--tape .friend-card__link::after {
  border-color: rgba(225, 230, 245, 0.1);
  box-shadow: 3px 4px 0 rgba(0, 0, 0, 0.16);
}

.tape-disabled .friend-card--tape .friend-card__link::before,
.tape-disabled .friend-card--tape .friend-card__link::after {
  display: none;
}

@media (max-width: 640px) {
  .friend-card--tape .friend-card__link::before {
    left: 16px;
  }
  .friend-card--tape .friend-card__link::after {
    top: 18px;
    right: -5px;
    width: 5px;
    height: 38px;
  }
  .friend-card--tape .friend-card__link:hover::after {
    right: -9px;
    width: 9px;
  }
}
