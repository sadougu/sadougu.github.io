/* ============== POST LIST (card grid) ============== */
.post-list {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18px;
}

.post-card {
  display: flex;
  flex-direction: column;
  padding: 14px;
  color: inherit;
  text-decoration: none;
  transition: transform 0.22s ease;
}

.post-card::before {
  transition: filter 0.22s ease;
}

.post-card a {
  color: inherit;
  text-decoration: none;
}

.post-card:hover {
  transform: translateY(-3px);
}

.post-card:hover::before {
  filter: url(#paper-edge) drop-shadow(var(--shadow));
}

.post-thumb-link {
  display: block;
  margin: -14px -14px 14px;
}

.post-thumb-link .paper-thumb {
  height: 130px;
  border-radius: 4px 4px 0 0;
}

.post-thumb-link .paper-thumb:not(.paper-thumb--cover) {
  filter: url(#paper-edge);
}

.post-thumb-link .paper-thumb::after {
  display: none;
}

.post-card-copy {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 0 4px;
}

.post-card h3 {
  margin: 0;
  font-size: 15px;
  font-weight: 700;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  word-break: break-word;
}

.post-card:hover h3 a,
.post-card h3 a:hover {
  color: var(--color-accent-strong);
}

.dark-mode .post-card:hover h3 a,
.dark-mode .post-card h3 a:hover {
  color: var(--color-accent-muted);
}

.post-card p {
  margin: 0;
  color: var(--muted);
  font-size: 13px;
  line-height: 1.6;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.post-card .meta-line {
  margin-top: 6px;
  font-size: 11px;
}

.post-card .meta-line--tags {
  margin-top: 8px;
}

.post-card .meta-line--tax {
  margin-top: 0;
}
