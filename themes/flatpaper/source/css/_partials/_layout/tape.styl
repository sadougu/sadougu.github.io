/* ============== TAPE DECORATION ============== */
.tape {
  position: absolute;
  z-index: 4;
  width: 86px;
  height: 22px;
  background-color: var(--tape-yellow);
  background-image: var(--tape-stripes);
  filter: saturate(0.88);
}

.tape--top-left {
  top: -10px;
  left: 24px;
  background-color: var(--tape-pink);
  transform: rotate(-6deg);
}

.tape--top-center {
  top: -10px;
  left: 50%;
  background-color: var(--tape-pink);
  transform: translateX(-50%) rotate(-2deg);
}

.tape--top-right {
  top: -10px;
  right: 32px;
  width: 70px;
  background-color: var(--tape-pink);
  background-image: var(--tape-stripes);
  transform: rotate(7deg);
}

.tape-disabled .tape,
.tape-disabled .side-card::before,
.tape-disabled .comments-section::after,
.tape-disabled .related-paper::after,
.tape-disabled .site-header::after,
.tape-disabled .welcome-thumb--image::before,
.tape-disabled .welcome-thumb--image::after {
  display: none;
}

.side-card::before {
  content: "";
  position: absolute;
  top: -10px;
  right: 18px;
  z-index: 2;
  width: 70px;
  height: 20px;
  background-color: var(--tape-yellow);
  background-image: var(--tape-stripes);
  filter: saturate(0.9);
  transform: rotate(6deg);
}
